# HeartFlow .gitignore

# Dependencies
node_modules/
package-lock.json
yarn.lock

# Build outputs
dist/
build/
*.min.js

# Logs
logs/
*.log
npm-debug.log*

# Environment
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Temporary files
tmp/
temp/
*.tmp

# Private user data (IMPORTANT!)
# Do NOT commit user-specific tasks or personal information
user-tasks/
private/
*.private.md
*privacy*.md

# Large media files
*.mp4
*.mov
*.avi
*.png
*.jpg
*.jpeg
*.gif
!docs/*.jpg
!docs/*.png

# Backup files
backups/
*.bak
*~

# Test coverage
coverage/

# TypeScript cache
*.tsbuildinfo

# HeartFlow self-awareness system (generated at runtime)
src/self/memory-store/
src/self/logs/

# User downloads (IMPORTANT! - NOT upload to GitHub)
downloads/
cache/
documents/
