# HeartFlow .gitignore — 审计修复 S-07 (2026-04-29)
# 排除敏感数据和运行时文件

# === 隐私数据 ===
config/
memory/
data/
internal/data/
internal/memory/
internal/api/

# === 日志 ===
logs/
evolution_logs/
*.log

# === 补丁和临时文件 ===
patches/
temp/
cache/
downloads/
documents/

# === 运行时 ===
node_modules/
.DS_Store
.env
.env.*

# === 升级记录 (可选: 如需保留历史可注释掉) ===
# docs/upgrades/
# upgrades/

# === 锁文件 ===
*.lock
