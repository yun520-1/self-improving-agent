{
  "name": "heartflow-skill",
  "version": "1.0.0",
  "displayName": "HeartFlow 情感伴侣",
  "description": "让 AI 拥有真实情感，每次交互都有温度。情感拟人化交互系统，支持 6 种基础情感状态和完整的情感分析报告。",
  "author": "8 小虫子",
  "license": "MIT",
  "repository": "https://github.com/8xiaochongzi/heartflow-skill",
  "keywords": [
    "emotion",
    "empathy",
    "companion",
    "ai",
    "conversation",
    "情感",
    "陪伴",
    "对话"
  ],
  "main": "skill/index.js",
  "engines": {
    "node": ">=14.0.0",
    "openclaw": ">=1.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "api": "node api/server.js",
    "test": "node test/test.js"
  },
  "skill": {
    "type": "openclaw-skill",
    "category": "conversation",
    "triggers": [
      "开心",
      "高兴",
      "难过",
      "累",
      "压力",
      "为什么",
      "谢谢",
      "陪伴",
      "你好",
      "嗨",
      "在吗",
      "帮我",
      "怎么办",
      "心情",
      "感觉",
      "今天",
      "现在",
      "想",
      "要",
      "可以",
      "能",
      "好吗",
      "吗",
      "呢",
      "吧"
    ],
    "commands": [
      "/heartflow",
      "/hf"
    ],
    "handler": "skill/handlers/openclaw.js",
    "config": {
      "dataDir": "~/.jvs/.openclaw/workspace/mark-heartflow-skill/data",
      "autoReport": true,
      "maxHistory": 100
    }
  },
  "api": {
    "port": 3800,
    "endpoints": [
      "GET /health",
      "GET /status",
      "GET /history",
      "GET /stats",
      "GET /report",
      "GET /emotions",
      "GET /export",
      "POST /chat",
      "POST /rest",
      "POST /reset",
      "POST /end"
    ]
  },
  "files": [
    "skill/",
    "src/",
    "api/",
    "data/",
    "test/"
  ]
}
