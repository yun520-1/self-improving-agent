{
  "name": "heartflow-skill",
  "version": "2.0.0",
  "displayName": "HeartFlow 情感伴侣 V2",
  "description": "让 AI 拥有真实情感，每次交互都有温度。V2 新增隐式学习、用户画像、共情深度系统，让情感通过后天交互不断进化。",
  "author": "8 小虫子",
  "license": "MIT",
  "category": "conversation",
  "tags": [
    "情感",
    "陪伴",
    "对话",
    "AI",
    "共情",
    "emotion",
    "empathy",
    "learning",
    "adaptive"
  ],
  "repository": "https://github.com/8xiaochongzi/heartflow-skill",
  "homepage": "https://github.com/8xiaochongzi/heartflow-skill#readme",
  "bugs": "https://github.com/8xiaochongzi/heartflow-skill/issues",
  "main": "skill/index.js",
  "skill": {
    "entry": "skill/index.js",
    "handler": "skill/handlers/openclaw.js",
    "commands": ["/heartflow", "/hf"],
    "triggers": ["开心", "高兴", "难过", "累", "压力", "为什么", "谢谢"]
  },
  "engines": {
    "node": ">=14.0.0",
    "openclaw": ">=1.0.0"
  },
  "features": [
    "6 种基础情感状态（平静、愉悦、好奇、关切、疲惫、兴奋）",
    "5 级情感强度",
    "情感转换分析和报告",
    "完整的记忆存储系统",
    "🔥 V2 新增：隐式学习系统（自动学习什么回应有效）",
    "🔥 V2 新增：用户画像系统（个性化情感偏好）",
    "🔥 V2 新增：共情深度模型（信任度决定回应深度）",
    "🔥 V2 新增：自适应情感转换概率",
    "RESTful API 接口",
    "OpenClaw Skill 集成",
    "CLI 交互界面"
  ],
  "screenshots": [],
  "changelog": {
    "2.0.0": "V2 重大升级 - 隐式学习系统、用户画像、共情深度模型、自适应概率调整",
    "1.0.0": "初始版本 - 核心情感系统、API 接口、Skill 集成"
  }
}
